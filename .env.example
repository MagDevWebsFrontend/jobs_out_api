# ==========================================
# ENTORNO Y PUERTOS
# ==========================================
NODE_ENV=development
PORT=4000
API_VERSION=v1
API_PREFIX=/api

# ==========================================
# BASE DE DATOS - DESARROLLO
# ==========================================
DB_DEV_HOST=localhost
DB_DEV_PORT=5432
DB_DEV_NAME=db-trabajos
DB_DEV_USER=postgres
DB_DEV_PASS=tu_password_aqui
DB_DEV_SSL=false

# ==========================================
# BASE DE DATOS - TEST
# ==========================================
DB_TEST_HOST=localhost
DB_TEST_PORT=5432
DB_TEST_NAME=trabajos_test
DB_TEST_USER=postgres
DB_TEST_PASS=tu_password_aqui
DB_TEST_SSL=false

# ==========================================
# BASE DE DATOS - PRODUCCION
# ==========================================
DB_PROD_HOST=localhost
DB_PROD_PORT=5432
DB_PROD_NAME=jobs_out_prod
DB_PROD_USER=postgres
DB_PROD_PASS=tu_password_produccion
DB_PROD_SSL=false

# ==========================================
# JWT Y SEGURIDAD
# ==========================================
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=tu_refresh_secret_super_seguro_aqui_cambiar
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ==========================================
# CORS Y SEGURIDAD
# ==========================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000
CORS_CREDENTIALS=true

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# UPLOAD CONFIG
# ==========================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
UPLOAD_PATH=./public/uploads

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_TO_FILE=true

# ==========================================
# TELEGRAM (NO CAMBIAR - Configuración fija del bot)
# ==========================================
TELEGRAM_BOT_TOKEN=8516521672:AAFWn1RyjKDNC7FvFmJxmOgJ_Ma5vCgR1Ak
TELEGRAM_BOT_USERNAME=@JobsOutCubaBot

# ==========================================
# APP CONFIG
# ==========================================
APP_NAME=Jobs Out Cuba
APP_DESCRIPTION=Plataforma de búsqueda de trabajos en Cuba
APP_URL=http://localhost:4000

# ==========================================
# SESSION (OPCIONAL)
# ==========================================
SESSION_SECRET=tu_session_secret_aqui
SESSION_MAX_AGE=86400000

# ==========================================
# EMAIL (OPCIONAL)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@jobsout.cu

# ==========================================
# REDIS (OPCIONAL)
# ==========================================
